# ─── APP ───
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
API_PREFIX=api/v1
CORS_ORIGINS=*

# ─── DATABASE ───
DATABASE_URL=postgresql://user:password@localhost:5432/ekkids?schema=public

# ─── REDIS (optional) ───
REDIS_URL=redis://localhost:6379

# ─── AUTH ───
JWT_SECRET=your-secret-key-at-least-32-chars-long
JWT_EXPIRES_IN=7d
SESSION_TOKEN_EXPIRES_IN=30d

# ─── AUDIO ───
AUDIO_STORAGE=local
AUDIO_PATH=./public/audio

# ─── SWAGGER ───
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# ─── RATE LIMIT ───
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
